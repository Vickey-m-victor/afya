{
    "openapi": "3.0.0",
    "info": {
        "title": "outpatient Module",
        "description": "API documentation for outpatient module",
        "contact": {
            "name": "Ananda Douglas",
            "email": "douglasdaggs@gmail.com"
        },
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://localhost:9364/v2",
            "description": "API Development Server"
        },
        {
            "url": "https://afya365.com/v2",
            "description": "API Staging Server"
        }
    ],
    "paths": {
        "/outpatient/registration/list": {
            "get": {
                "tags": [
                    "Registration"
                ],
                "summary": "Recent patients (Reception quick list)",
                "parameters": [
                    {
                        "name": "limit",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "example": 10
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Recent patient list"
                    }
                }
            }
        },
        "/outpatient/registration/meta": {
            "get": {
                "tags": [
                    "Registration"
                ],
                "summary": "Registration metadata (dropdown values)",
                "responses": {
                    "200": {
                        "description": "Metadata for registration forms"
                    }
                }
            }
        },
        "/outpatient/registration/search": {
            "get": {
                "tags": [
                    "Registration"
                ],
                "summary": "Quick search patients (Reception)",
                "parameters": [
                    {
                        "name": "facility_id",
                        "in": "query",
                        "description": "Facility ID to scope patients",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "example": 1
                        }
                    },
                    {
                        "name": "q",
                        "in": "query",
                        "description": "Search term (name, MRN, phone)",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "example": "John"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Search results"
                    },
                    "400": {
                        "description": "Missing facility_id"
                    }
                }
            }
        },
        "/outpatient/registration/find-or-create": {
            "post": {
                "tags": [
                    "Registration"
                ],
                "summary": "Find existing patient or create new one (Safe entry point)",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/RegistrationQuickRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Patient found or created"
                    },
                    "400": {
                        "description": "Missing facility_id"
                    },
                    "422": {
                        "description": "Validation errors"
                    }
                }
            }
        },
        "/outpatient/registration": {
            "post": {
                "tags": [
                    "Registration"
                ],
                "summary": "Register patient only (optional endpoint)",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/RegistrationQuickRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Patient created"
                    },
                    "422": {
                        "description": "Validation errors"
                    }
                }
            }
        },
        "/outpatient/registration/start-encounter": {
            "post": {
                "tags": [
                    "Registration"
                ],
                "summary": "Find/Create patient and start encounter (Reception Flow)",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/RegistrationQuickRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Patient + Encounter created and sent to triage"
                    },
                    "422": {
                        "description": "Validation errors"
                    }
                }
            }
        },
        "/outpatient/registration/{id}": {
            "get": {
                "tags": [
                    "Registration"
                ],
                "summary": "View patient (Reception)",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "example": 1
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Patient details"
                    },
                    "404": {
                        "description": "Patient not found"
                    }
                }
            }
        }
    },
    "components": {
