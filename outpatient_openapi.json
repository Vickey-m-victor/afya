                "type": "object"
            },
            "RegistrationQuickRequest": {
                "required": [
                    "first_name",
                    "last_name",
                    "date_of_birth"
                ],
                "properties": {
                    "facility_id": {
                        "type": "integer",
                        "example": 1
                    },
                    "first_name": {
                        "type": "string",
                        "example": "John"
                    },
                    "last_name": {
                        "type": "string",
                        "example": "Doe"
                    },
                    "date_of_birth": {
                        "type": "string",
                        "format": "date",
                        "example": "1990-01-01"
                    },
                    "gender": {
                        "type": "integer",
                        "example": 1
                    },
                    "contacts": {
                        "type": "array",
                        "items": {
                            "properties": {
                                "type": {
                                    "type": "string",
                                    "example": "phone"
                                },
                                "value": {
                                    "type": "string",
                                    "example": "254700000000"
                                }
                            },
                            "type": "object"
                        }
                    },
                    "identifiers": {
                        "type": "array",
                        "items": {
                            "properties": {
                                "type": {
                                    "type": "string",
                                    "example": "NATIONAL_ID"
                                },
                                "value": {
                                    "type": "string",
                                    "example": "12345678"
                                }
                            },
                            "type": "object"
                        }
                    },
                    "encounter_type_id": {
                        "type": "integer",
                        "example": 1
                    },
                    "department_id": {
                        "type": "integer",
                        "example": 2
                    }
                },
                "type": "object"
            }
        }
