                    "to_department_id": {
                        "title": "To department id",
                        "type": "int",
                        "example": "int"
                    },
                    "to_doctor_id": {
                        "title": "To doctor id",
                        "type": "int",
                        "example": "int"
                    },
                    "to_facility_name": {
                        "title": "To facility name",
                        "type": "string",
                        "example": "string"
                    },
                    "to_speciality": {
                        "title": "To speciality",
                        "type": "string",
                        "example": "string"
                    },
                    "reason_icd10_id": {
                        "title": "Reason icd10 id",
                        "type": "int",
                        "example": "int"
                    },
                    "reason_text": {
                        "title": "Reason text",
